{
  "info": {
    "name": "Online Store API - Phase 1-2 (Catalog)",
    "description": "Category and Product endpoints only. No auth yet - added in Phase 3.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "categoryId", "value": "1" },
    { "key": "productId", "value": "1" }
  ],
  "item": [
    {
      "name": "Categories",
      "item": [
        {
          "name": "List categories",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/categories?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["api", "categories"], "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "20" } ] }
          }
        },
        {
          "name": "Get category by id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api", "categories", "{{categoryId}}"] }
          }
        },
        {
          "name": "Create category",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api", "categories"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Toys\",\n  \"description\": \"Toys and games\"\n}"
            }
          }
        },
        {
          "name": "Update category",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api", "categories", "{{categoryId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Toys & Games\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete category",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api", "categories", "{{categoryId}}"] }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List products (with filters)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products?page=0&size=20&categoryId={{categoryId}}&active=true",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" },
                { "key": "categoryId", "value": "{{categoryId}}" },
                { "key": "active", "value": "true" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "minPrice", "value": "", "disabled": true },
                { "key": "maxPrice", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get product by id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}"] }
          }
        },
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api", "products"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"TOY-0001\",\n  \"name\": \"Building Blocks Set\",\n  \"description\": \"200-piece building blocks\",\n  \"price\": 29.99,\n  \"stockQuantity\": 50,\n  \"categoryId\": {{categoryId}}\n}"
            }
          }
        },
        {
          "name": "Update product",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"TOY-0001\",\n  \"name\": \"Building Blocks Set (Deluxe)\",\n  \"description\": \"350-piece building blocks\",\n  \"price\": 34.99,\n  \"stockQuantity\": 40,\n  \"categoryId\": {{categoryId}}\n}"
            }
          }
        },
        {
          "name": "Adjust stock",
          "request": {
            "method": "PATCH",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}/stock", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}", "stock"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"delta\": -5\n}"
            }
          }
        },
        {
          "name": "Deactivate product (soft delete)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}"] }
          }
        }
      ]
    }
  ]
}
