{
  "info": {
    "name": "Online Store API - Full (Phase 1-5)",
    "description": "Categories, Products, Auth, Customers, Addresses, Cart, Orders. Login requests auto-save accessToken/refreshToken via a small Tests script.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "categoryId", "value": "1" },
    { "key": "productId", "value": "1" },
    { "key": "addressId", "value": "1" },
    { "key": "orderId", "value": "1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Categories",
      "item": [
        { "name": "List categories", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/categories?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["api", "categories"], "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "20" } ] } } },
        { "name": "Get category by id", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api", "categories", "{{categoryId}}"] } } },
        { "name": "Create category (staff)", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/categories", "host": ["{{baseUrl}}"], "path": ["api", "categories"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Toys\",\n  \"description\": \"Toys and games\"\n}" } } },
        { "name": "Update category (staff)", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api", "categories", "{{categoryId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"name\": \"Toys & Games\",\n  \"description\": \"Updated description\"\n}" } } },
        { "name": "Delete category (staff)", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/categories/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api", "categories", "{{categoryId}}"] } } }
      ]
    },
    {
      "name": "Products",
      "item": [
        { "name": "List products (with filters)", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/products?page=0&size=20&categoryId={{categoryId}}&active=true", "host": ["{{baseUrl}}"], "path": ["api", "products"], "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "20" }, { "key": "categoryId", "value": "{{categoryId}}" }, { "key": "active", "value": "true" } ] } } },
        { "name": "Get product by id", "request": { "method": "GET", "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}"] } } },
        { "name": "Create product (staff)", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/products", "host": ["{{baseUrl}}"], "path": ["api", "products"] }, "body": { "mode": "raw", "raw": "{\n  \"sku\": \"TOY-0001\",\n  \"name\": \"Building Blocks Set\",\n  \"description\": \"200-piece building blocks\",\n  \"price\": 29.99,\n  \"stockQuantity\": 50,\n  \"categoryId\": {{categoryId}}\n}" } } },
        { "name": "Update product (staff)", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"sku\": \"TOY-0001\",\n  \"name\": \"Building Blocks Set (Deluxe)\",\n  \"description\": \"350-piece building blocks\",\n  \"price\": 34.99,\n  \"stockQuantity\": 40,\n  \"categoryId\": {{categoryId}}\n}" } } },
        { "name": "Adjust stock (staff)", "request": { "method": "PATCH", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/products/{{productId}}/stock", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}", "stock"] }, "body": { "mode": "raw", "raw": "{\n  \"delta\": -5\n}" } } },
        { "name": "Deactivate product (staff)", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/products/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "products", "{{productId}}"] } } }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login - customer",
          "event": [ { "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "    const data = pm.response.json();",
            "    pm.collectionVariables.set('accessToken', data.accessToken);",
            "    pm.collectionVariables.set('refreshToken', data.refreshToken);",
            "}"
          ] } } ],
          "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": { "raw": "{{baseUrl}}/api/auth/customers/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "customers", "login"] }, "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane.doe@example.com\",\n  \"password\": \"Customer@123\"\n}" } }
        },
        {
          "name": "Login - staff (admin)",
          "event": [ { "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "    const data = pm.response.json();",
            "    pm.collectionVariables.set('accessToken', data.accessToken);",
            "    pm.collectionVariables.set('refreshToken', data.refreshToken);",
            "}"
          ] } } ],
          "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": { "raw": "{{baseUrl}}/api/auth/staff/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "staff", "login"] }, "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@code81.local\",\n  \"password\": \"Admin@123\"\n}" } }
        },
        {
          "name": "Refresh token",
          "event": [ { "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "    const data = pm.response.json();",
            "    pm.collectionVariables.set('accessToken', data.accessToken);",
            "    pm.collectionVariables.set('refreshToken', data.refreshToken);",
            "}"
          ] } } ],
          "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "auth", "refresh"] }, "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" } }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "auth", "logout"] }, "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" } }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        { "name": "Register", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" } ], "url": { "raw": "{{baseUrl}}/api/customers/register", "host": ["{{baseUrl}}"], "path": ["api", "customers", "register"] }, "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Smith\",\n  \"email\": \"john.smith@example.com\",\n  \"password\": \"Password123\",\n  \"phone\": \"+201111111111\"\n}" } } },
        { "name": "Get my profile", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/customers/me", "host": ["{{baseUrl}}"], "path": ["api", "customers", "me"] } } },
        { "name": "Update my profile", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/customers/me", "host": ["{{baseUrl}}"], "path": ["api", "customers", "me"] }, "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"Jane\",\n  \"lastName\": \"Doe-Updated\",\n  \"phone\": \"+201234567890\"\n}" } } },
        { "name": "Change password", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/customers/me/change-password", "host": ["{{baseUrl}}"], "path": ["api", "customers", "me", "change-password"] }, "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"Customer@123\",\n  \"newPassword\": \"NewPassword123\"\n}" } } }
      ]
    },
    {
      "name": "Addresses",
      "item": [
        { "name": "List my addresses", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/customers/me/addresses", "host": ["{{baseUrl}}"], "path": ["api", "customers", "me", "addresses"] } } },
        { "name": "Add address", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/customers/me/addresses", "host": ["{{baseUrl}}"], "path": ["api", "customers", "me", "addresses"] }, "body": { "mode": "raw", "raw": "{\n  \"label\": \"Work\",\n  \"line1\": \"5 Tahrir Square\",\n  \"city\": \"Cairo\",\n  \"country\": \"Egypt\",\n  \"isDefault\": false\n}" } } },
        { "name": "Update address", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/customers/me/addresses/{{addressId}}", "host": ["{{baseUrl}}"], "path": ["api", "customers", "me", "addresses", "{{addressId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"label\": \"Work (updated)\",\n  \"line1\": \"5 Tahrir Square, Floor 3\",\n  \"city\": \"Cairo\",\n  \"country\": \"Egypt\",\n  \"isDefault\": true\n}" } } },
        { "name": "Delete address", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/customers/me/addresses/{{addressId}}", "host": ["{{baseUrl}}"], "path": ["api", "customers", "me", "addresses", "{{addressId}}"] } } }
      ]
    },
    {
      "name": "Cart",
      "item": [
        { "name": "Get my cart", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/cart", "host": ["{{baseUrl}}"], "path": ["api", "cart"] } } },
        { "name": "Add item to cart", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/cart/items", "host": ["{{baseUrl}}"], "path": ["api", "cart", "items"] }, "body": { "mode": "raw", "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 2\n}" } } },
        { "name": "Update item quantity", "request": { "method": "PUT", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/cart/items/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "cart", "items", "{{productId}}"] }, "body": { "mode": "raw", "raw": "{\n  \"quantity\": 3\n}" } } },
        { "name": "Remove item from cart", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/cart/items/{{productId}}", "host": ["{{baseUrl}}"], "path": ["api", "cart", "items", "{{productId}}"] } } },
        { "name": "Clear cart", "request": { "method": "DELETE", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/cart", "host": ["{{baseUrl}}"], "path": ["api", "cart"] } } }
      ]
    },
    {
      "name": "Orders",
      "item": [
        { "name": "Place order (from cart)", "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/orders", "host": ["{{baseUrl}}"], "path": ["api", "orders"] }, "body": { "mode": "raw", "raw": "{\n  \"addressId\": {{addressId}}\n}" } } },
        { "name": "List my orders", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/orders/me?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["api", "orders", "me"], "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "20" } ] } } },
        { "name": "List all orders (staff)", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/orders?page=0&size=20", "host": ["{{baseUrl}}"], "path": ["api", "orders"], "query": [ { "key": "page", "value": "0" }, { "key": "size", "value": "20" }, { "key": "status", "value": "PLACED", "disabled": true } ] } } },
        { "name": "Get order by id", "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{orderId}}"] } } },
        { "name": "Update status - mark PAID (staff)", "request": { "method": "PATCH", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{orderId}}", "status"] }, "body": { "mode": "raw", "raw": "{\n  \"status\": \"PAID\"\n}" } } },
        { "name": "Cancel order (customer)", "request": { "method": "PATCH", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Authorization", "value": "Bearer {{accessToken}}" } ], "url": { "raw": "{{baseUrl}}/api/orders/{{orderId}}/status", "host": ["{{baseUrl}}"], "path": ["api", "orders", "{{orderId}}", "status"] }, "body": { "mode": "raw", "raw": "{\n  \"status\": \"CANCELLED\"\n}" } } }
      ]
    }
  ]
}
